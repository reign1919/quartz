  "royaltyProgram": {
    "enabled": true,
    "description": "Contributors earn a royalty split on every download of their materials.",
    "highlights": [
      "Passive income from existing notes",
      "Royalty split on every download",
      "Contributor credits and recognition",
      "Growing student audience"
