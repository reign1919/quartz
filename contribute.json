  "postTenthGrades": ["Grade 11", "Grade 12", "1st Year (College)", "2nd Year (College)", "3rd Year (College)", "4th Year (College)"],
  "streams": [
    "Science (PCM)",
    "Science (PCB)",
    "Science (PCMB)",
    "Commerce",
    "Arts / Humanities",
    "Computer Science",
    "Engineering",
    "Medical / Healthcare",
    "Other"
